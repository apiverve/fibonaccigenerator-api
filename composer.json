        "fibonacci",
        "fibonacci sequence",
        "fibonacci generator",
        "golden ratio",
        "math sequence"
    ],
    "homepage": "https://apiverve.com/marketplace/fibonaccigenerator?utm_source=php&utm_medium=homepage",
    "support": {
        "email": "hello@apiverve.com",
        "docs": "https://docs.apiverve.com/ref/fibonaccigenerator",
